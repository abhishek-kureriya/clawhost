# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit your real token.

do_token            = "your_digitalocean_personal_access_token"
project_name        = "clawhost"
environment         = "production"

# Cheapest options:
#   s-1vcpu-1gb  → $6/mo  (tight, not recommended for full stack)
#   s-1vcpu-2gb  → $12/mo ← good starting point
#   s-2vcpu-4gb  → $24/mo (comfortable for MCP + OpenClaw + Postgres)
droplet_size        = "s-1vcpu-2gb"

# Region: ams3 | nyc3 | sgp1 | lon1 | fra1 | blr1 | tor1 | syd1
region              = "ams3"

enable_backups      = false

ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Restrict to your IP in production:
# allowed_ssh_ips = ["1.2.3.4/32"]
allowed_ssh_ips     = ["0.0.0.0/0", "::/0"]

repo_url            = "https://github.com/abhishek-kureriya/clawhost.git"
go_version          = "1.23.4"
node_version        = "20"
