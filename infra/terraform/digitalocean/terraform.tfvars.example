# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit your real token.

# do_token is auto-read from doctl's config by the Makefile (TF_VAR_do_token).
# Uncomment and set manually only if you are NOT using doctl or running Terraform
# directly (outside of make):
# do_token = "dop_v1_..."
project_name        = "clawhost"
environment         = "production"

# Cheapest options:
#   s-1vcpu-1gb  → $6/mo  ← default
#   s-1vcpu-2gb  → $12/mo
#   s-2vcpu-4gb  → $24/mo (comfortable for MCP + OpenClaw + Postgres)
droplet_size        = "s-1vcpu-1gb"

# Region: ams3 | nyc3 | sgp1 | lon1 | fra1 | blr1 | tor1 | syd1
region              = "ams3"

enable_backups      = false

ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Restrict to your IP in production:
# allowed_ssh_ips = ["1.2.3.4/32"]
allowed_ssh_ips     = ["0.0.0.0/0", "::/0"]

repo_url            = "https://github.com/abhishek-kureriya/clawhost.git"
go_version          = "1.23.4"
node_version        = "20"

# ---- Domains (optional) ---------------------------------------------------
# Set these to use your domain instead of the raw server IP.
# DNS A records must point to the droplet IP BEFORE provisioning for SSL to work.
# If left empty, nginx will serve on IP only (HTTP).
api_domain          = "api.bharatfinx.com"
app_domain          = "app.bharatfinx.com"
letsencrypt_email   = "admin@bharatfinx.com"

# OpenClaw is installed via the Core API after provisioning:
# POST https://api.bharatfinx.com/api/v1/provision
# { "provider": "local", "openclaw_repo_url": "https://github.com/your-org/openclaw.git", ... }
