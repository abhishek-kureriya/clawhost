# Server-side .env for ClawHost
# Place this at /opt/clawhost/app/.env on the server.
# Copy from .env.example and fill in all required values.

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=clawhost
DB_PASSWORD=change_me_strong_password
DB_NAME=clawhost_db
DB_SSLMODE=disable

# ── ClawHost Core API ─────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=production
JWT_SECRET=change_me_64_char_random_secret

# ── OpenClaw UI ───────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change_me_secret_key

# ── LLM Provider (one or more) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ── MCP Bridge — Big 5 services ───────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
PG_CONNECTION_STRING=postgresql://clawhost:change_me_strong_password@localhost:5432/clawhost_db
GOOGLE_CREDENTIALS_JSON=
TAVILY_API_KEY=

# ── Hetzner (used by core provisioning) ──────────────────────────────────────
HETZNER_API_TOKEN=

# ── Stripe (used by hosting-service) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
